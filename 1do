- name: Find all modprobe conf files
  ansible.builtin.find:
    paths: /etc/modprobe.d/
    patterns: "*.conf"
  register: modprobe_files
  tags:
    - NNP

- name: Disable uncommon network protocols in all conf files
  ansible.builtin.lineinfile:
    path: "{{ item.0.path }}"
    line: "{{ item.1 }}"
    state: present
    create: yes
  loop: "{{ modprobe_files.files | product(['install dccp /bin/true', 'install sctp /bin/true', 'install rds /bin/true', 'install tipc /bin/true']) | list }}"
  register: output15
  tags:
    - NNP

- name: Output of point 2.15.1
  ansible.builtin.debug:
    msg: "{{ output15 }}"
  tags:
    - NNP
