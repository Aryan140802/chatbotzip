- name: 2.15.1 Uncommon Network Protocols to be disabled

- name: Find all modprobe conf files
  ansible.builtin.find:
    paths: /etc/modprobe.d/
    patterns: "*.conf"
  register: modprobe_files
  tags:
    - NetworkProtocol


- name: Disable uncommon network protocols
  ansible.builtin.lineinfile:
    path: "{{ item.0.path }}"
    line: "{{ item.1 }}"
    state: present
    create: yes
  with_nested:
    - "{{ modprobe_files.files }}"
    -
      - "install dccp /bin/true"
      - "install sctp /bin/true"
      - "install rds /bin/true"
      - "install tipc /bin/true"
  register: output15
  tags:
    - NetworkProtocol


- name: Output of point 2.15.1
  debug:
    msg: "{{ output15 }}"
  tags:
    - NetworkProtocol
